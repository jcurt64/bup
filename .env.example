# ─────────────────────────────────────────────────────────────────────
# BUUPP — Variables d'environnement (template)
# Copie ce fichier en `.env.local` puis remplace chaque valeur.
# `.env.local` est gitignored → ne sera jamais commit.
# ─────────────────────────────────────────────────────────────────────

# ─── Supabase ────────────────────────────────────────────────────────
# Tableau de bord : https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
# Clé service_role : usage SERVEUR UNIQUEMENT (ne jamais exposer côté client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ─── Clerk (authentification) ────────────────────────────────────────
# Tableau de bord : https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Webhook signing secret (Clerk → Webhooks → endpoint settings)
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...
# URLs de redirection après auth (optionnel, fallback sur la racine)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/connexion
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/inscription
# Clerk v7+ : utilise les variables FALLBACK_REDIRECT_URL / FORCE_REDIRECT_URL.
# Les anciennes AFTER_SIGN_*_URL ne sont plus lues.
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/prospect
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/prospect

# ─── Stripe (paiements) ──────────────────────────────────────────────
# Tableau de bord : https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secret (Developers → Webhooks → endpoint signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── App ─────────────────────────────────────────────────────────────
# Utilisé pour construire les URLs absolues (Stripe success/cancel, e-mails…)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── E-mail (mails de confirmation liste d'attente) ─────────────────
# Transport SMTP. Pour Gmail :
#   1. Activer 2FA sur le compte : https://myaccount.google.com/security
#   2. Générer un mot de passe d'application (16 caractères, sans espaces)
#      → https://myaccount.google.com/apppasswords
#   3. Coller ce mot de passe dans SMTP_PASS (PAS le mot de passe Google).
# Si SMTP_USER ou SMTP_PASS sont vides, l'envoi est silencieusement désactivé
# (l'inscription continue de fonctionner sans mail).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=jjlex64@gmail.com
SMTP_PASS=
# Optionnel : "BUUPP <jjlex64@gmail.com>" — sinon construit automatiquement.
MAIL_FROM=BUUPP <jjlex64@gmail.com>

# Sel pour le hash IP des inscriptions (anti-spam, RGPD-friendly).
WAITLIST_IP_SALT=change-me-to-something-random

# ─── Brevo (ex-Sendinblue) — SMS de vérification téléphone ──────────
# Tableau de bord : https://app.brevo.com/
#   1. Crée une clé API : Account → SMTP & API → API Keys → "Generate
#      a new API key" (format : xkeysib-…).
#   2. Vérifie ton compte SMS : Brevo → Campaigns → SMS → "Buy SMS
#      credits" (100 SMS gratuits offerts à la 1ère commande).
#   3. (Optionnel) BREVO_SMS_SENDER : nom alphanumérique max 11 chars
#      affiché comme expéditeur côté téléphone destinataire.
# Si BREVO_API_KEY manque, /api/prospect/phone/start bascule en mode
# dev (le code généré est renvoyé dans la réponse, pas de SMS envoyé).
BREVO_API_KEY=xkeysib-...
BREVO_SMS_SENDER=BUUPP

# Liste blanche d'emails admin pour /buupp-admin (séparés par virgule).
# FAIL-CLOSED : si vide, personne ne peut accéder au dashboard.
ADMIN_EMAILS=jjlex64@gmail.com

# Secret partagé pour les déclencheurs machine (cron Vercel, scripts CLI).
# Vercel injecte automatiquement Authorization: Bearer $CRON_SECRET pour
# les jobs cron — mettre la même valeur dans CRON_SECRET côté Vercel.
BUUPP_ADMIN_SECRET=change-me-long-random-string
CRON_SECRET=change-me-long-random-string

# Take-rate utilisé pour estimer le revenu BUUPP affiché.
# Float entre 0 et 1. Defaut : 0.20.
BUUPP_TAKE_RATE=0.20
