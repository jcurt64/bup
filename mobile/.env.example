# BUUPP Mobile — variables d'environnement (cf. MOBILE_APP_SPEC.md §4)
#
# Toutes préfixées EXPO_PUBLIC_ → injectées dans le bundle (PUBLIQUES,
# pas de secret ici). Copier ce fichier en `.env` et renseigner.
#
# ⚠️ Les clés Clerk / Stripe / Supabase DOIVENT être celles du MÊME
# environnement que le web (les NEXT_PUBLIC_* du projet web : test⇄test,
# live⇄live), sinon mobile et web ne pointent pas sur les mêmes
# utilisateurs / données.

# Base de l'API = backend web (source unique). Prod actuelle :
EXPO_PUBLIC_API_BASE_URL=https://bup-rouge.vercel.app
# (au déploiement du domaine : https://www.buupp.com)

# Clerk — MÊME projet/env que NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY du web
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Stripe — uniquement si on utilise @stripe/stripe-react-native (sinon
# le Checkout via WebBrowser n'en a pas besoin). MÊME env que le web.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Supabase — UNIQUEMENT pour le Realtime lecture seule (optionnel, §6.3).
# Pas utilisé pour les lectures/écritures métier (qui passent par /api/*).
EXPO_PUBLIC_SUPABASE_URL=https://yalgztstdmytviiyvixz.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
